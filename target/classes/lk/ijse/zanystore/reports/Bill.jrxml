	<query language="sql"><![CDATA[SELECT payment.payment_id, payment.payment_amount, customer.customer_name, order_payment_details.date FROM order_payment_details JOIN payment  on payment.payment_id = order_payment_details.payment_id JOIN customer ON order_payment_details.customer_id = customer.customer_id ORDER BY payment_id DESC LIMIT 1;]]></query>
