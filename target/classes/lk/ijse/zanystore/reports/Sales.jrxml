	<query language="sql"><![CDATA[SELECT p.payment_id, p.payment_amount, o.cloth_order_id, c.customer_name, o.date FROM payment p JOIN order_payment_details o ON p.payment_id = o.payment_id JOIN cloth_order co on o.cloth_order_id = co.cloth_order_id JOIN customer c on o.customer_id = c.customer_id and co.customer_id = c.customer_id]]></query>
