<jasperReport name="Quotation" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a55531bd-c577-49b7-813e-b1dda9e7b4e9">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Mysql"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<query language="sql"><![CDATA[SELECT
    q.quotation_id,
    q.customer_name,
    q.total_amount,
    qi.item_name,
    qi.color,
    qi.quantity,
    qi.unit_price,
    (qi.quantity * qi.unit_price) AS line_total
FROM quotation q
JOIN quotation_item qi
    ON q.quotation_id = qi.quotation_id
WHERE q.quotation_id = (
    SELECT MAX(quotation_id) FROM quotation
);
]]></query>
